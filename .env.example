# Required
OVERBUILD_LLM_PROVIDER=anthropic
OVERBUILD_LLM_MODEL=claude-sonnet-4-20250514
OVERBUILD_LLM_API_KEY=sk-...

# Recommended
OVERBUILD_LIBRARIESIO_API_KEY=...
OVERBUILD_GITHUB_TOKEN=ghp_...
OVERBUILD_STACKOVERFLOW_API_KEY=...

# Optional provider-specific keys (fallback if OVERBUILD_LLM_API_KEY is empty)
OVERBUILD_ANTHROPIC_API_KEY=sk-ant-...
OVERBUILD_OPENAI_API_KEY=sk-proj-...
OVERBUILD_GOOGLE_API_KEY=...

# Optional
OVERBUILD_CACHE_BACKEND=memory
OVERBUILD_DEBUG=true
